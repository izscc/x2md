{
    "manifest_version": 3,
    "name": "X2MD - 网页内容转Markdown",
    "version": "4.0.0",
    "description": "连接 X2MD 桌面 App，一键保存 X、LINUX DO、飞书和微信公众号内容为 Markdown",
    "permissions": [
        "storage",
        "notifications",
        "cookies",
        "tabs",
        "scripting",
        "alarms"
    ],
    "host_permissions": [
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "https://linux.do/*",
        "https://*.feishu.cn/wiki/*",
        "https://*.feishu.cn/docx/*",
        "https://mp.weixin.qq.com/*",
        "http://127.0.0.1:9527/*",
        "https://cdn.syndication.twimg.com/*",
        "https://publish.twitter.com/*",
        "https://translate.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/copy_5304228.png",
                "icons/translate_16818360.png"
            ],
            "matches": [
                "*://*.twitter.com/*",
                "*://*.x.com/*"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.twitter.com/*",
                "*://*.x.com/*",
                "https://linux.do/*",
                "https://*.feishu.cn/wiki/*",
                "https://*.feishu.cn/docx/*",
                "https://mp.weixin.qq.com/*"
            ],
            "js": [
                "dom_utils.js",
                "article_markdown.js",
                "discourse.js",
                "feishu.js",
                "wechat.js",
                "site_actions.js",
                "i18n.js",
                "twitter_graphql.js",
                "translation_helpers.js",
                "x-translation-ui.js",
                "bookmark_semantics.js",
                "capture_ui.js",
                "capture_contract.js",
                "site-adapters/web-capture.js",
                "site-adapters/x-capture.js",
                "x-batch-capture.js",
                "content_runtime.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "options_page": "options.html",
    "version_name": "4.0.0"
}
