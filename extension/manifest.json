{
    "manifest_version": 3,
    "name": "X2MD - 网页内容转Markdown",
    "version": "1.5.0",
    "description": "支持 X、LINUX DO、飞书知识库、飞书云文档、微信公众号的一键保存 Markdown，多目标保存（Obsidian/飞书多维表格/Notion/HTML），支持评论提取、iframe嵌入、Discourse多域名",
    "permissions": [
        "storage",
        "notifications",
        "cookies",
        "tabs",
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "https://linux.do/*",
        "https://*.feishu.cn/wiki/*",
        "https://*.feishu.cn/docx/*",
        "https://*.feishu.cn/docs/*",
        "https://*.feishu.cn/minutes/*",
        "https://*.feishu.cn/sheets/*",
        "https://*.feishu.cn/mindnotes/*",
        "https://*.larksuite.com/wiki/*",
        "https://*.larksuite.com/docx/*",
        "https://*.larksuite.com/minutes/*",
        "https://mp.weixin.qq.com/*",
        "http://127.0.0.1/*",
        "https://cdn.syndication.twimg.com/*",
        "https://publish.twitter.com/*",
        "https://abs.twimg.com/*",
        "https://open.feishu.cn/*",
        "https://open.larksuite.com/*",
        "https://api.notion.com/*"
    ],
    "optional_host_permissions": [
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.twitter.com/*",
                "*://*.x.com/*",
                "https://linux.do/*",
                "https://*.feishu.cn/wiki/*",
                "https://*.feishu.cn/docx/*",
                "https://*.feishu.cn/docs/*",
                "https://*.feishu.cn/minutes/*",
                "https://*.feishu.cn/sheets/*",
                "https://*.feishu.cn/mindnotes/*",
                "https://*.larksuite.com/wiki/*",
                "https://*.larksuite.com/docx/*",
                "https://*.larksuite.com/minutes/*",
                "https://mp.weixin.qq.com/*"
            ],
            "js": [
                "dom_utils.js",
                "article_markdown.js",
                "discourse.js",
                "feishu.js",
                "wechat.js",
                "site_actions.js",
                "twitter_graphql.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "options_page": "options.html"
}
