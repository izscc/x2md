{
  "name": "x2md",
  "version": "2.0.0-lite",
  "private": true,
  "scripts": {
    "dev": "electrobun dev",
    "build:dev": "electrobun build && npm run postbuild:extension",
    "build:mac": "electrobun build --env=stable && npm run postbuild:extension",
    "serve:node": "node app/main/index.ts",
    "test:js": "node --test app/tests/*.test.ts extension/tests/*.test.js tests/*.js",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test": "npm run test:js && npm run test:python",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "postbuild:extension": "npm run sync:extension-version && node scripts/copy-extension-to-apps.mjs",
    "smoke:mac": "node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:autostart": "X2MD_SMOKE_AUTOSTART=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:first-run": "X2MD_SMOKE_FIRST_RUN=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:port-conflict": "X2MD_SMOKE_PORT_CONFLICT=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:release": "mkdir -p /tmp/x2md-release-smoke && ditto -x -k release/v2.0.0-lite/X2MD_Mac.zip /tmp/x2md-release-smoke && X2MD_SMOKE_APP=/tmp/x2md-release-smoke/X2MD.app node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:login-autostart": "X2MD_SMOKE_LOGIN_AUTOSTART=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:extension-health": "X2MD_SMOKE_EXTENSION_HEALTH=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:mac:window-visible": "X2MD_SMOKE_WINDOW_VISIBLE=1 node scripts/smoke-packaged-mac.mjs",
    "smoke:chrome-extension-load": "node scripts/smoke-chrome-extension-load.mjs",
    "smoke:mac:menu-visible": "X2MD_SMOKE_MENU_VISIBLE=1 node scripts/smoke-packaged-mac.mjs",
    "acceptance:mac:auto": "npm run check && npm run build:mac && npm run smoke:mac && npm run smoke:mac:startup-time && npm run smoke:mac:port-conflict && npm run smoke:mac:autostart && npm run smoke:mac:login-autostart && npm run smoke:mac:first-run && npm run smoke:mac:extension-health && npm run smoke:chrome-extension-load && npm run smoke:mac:menu-visible && npm run smoke:mac:release && npm run check:release-artifacts",
    "check:release-artifacts": "node scripts/check-release-artifacts.mjs",
    "smoke:mac:startup-time": "node scripts/smoke-mac-startup-time.mjs",
    "sync:extension-version": "node scripts/sync-extension-version.mjs"
  },
  "dependencies": {
    "electrobun": "^1.18.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5.0.0"
  }
}
